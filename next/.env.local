# Modo de datos
# true  → hooks locales (sin PocketBase, sin red)
# false → PocketBase real
NEXT_PUBLIC_USE_MOCK=false

# PocketBase — URL pública (visible en el browser para SSE/auth)
NEXT_PUBLIC_PB_URL=http://192.168.0.84:8090

# PocketBase — URL interna (server-side / seed script)
PB_URL=http://192.168.0.84:8090
