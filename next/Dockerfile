FROM node:22-alpine AS base
RUN corepack enable

# ── Stage 1: install all deps ────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY packages/core/package.json        ./packages/core/
COPY next/package.json                 ./next/

RUN pnpm install --frozen-lockfile

# ── Stage 2: build ───────────────────────────────────────────────────────────
FROM base AS builder
WORKDIR /app

COPY --from=deps /app/node_modules                       ./node_modules
COPY --from=deps /app/packages/core/node_modules         ./packages/core/node_modules

COPY . .

ENV NEXT_TELEMETRY_DISABLED=1

# NEXT_PUBLIC_* vars are baked in at build time
ARG NEXT_PUBLIC_PB_URL
ARG NEXT_PUBLIC_USE_MOCK=false
ENV NEXT_PUBLIC_PB_URL=$NEXT_PUBLIC_PB_URL
ENV NEXT_PUBLIC_USE_MOCK=$NEXT_PUBLIC_USE_MOCK

RUN pnpm --filter @servicar/next build

# ── Stage 3: minimal runtime image ───────────────────────────────────────────
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid 1001 nextjs

# standalone output includes its own node_modules trace
COPY --from=builder --chown=nextjs:nodejs /app/next/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/next/.next/static     ./next/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/next/public           ./next/public

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# server.js is generated by standalone output at monorepo root level
CMD ["node", "next/server.js"]
